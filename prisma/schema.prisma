generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  createdAt     DateTime       @default(now())
  savedColleges SavedCollege[]
  questions     Question[]
  answers       Answer[]
}

model College {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  city            String
  state           String
  fees            Int
  rating          Float          @default(0)
  type            String
  establishedYear Int
  overview        String
  courses         Course[]
  placements      Placement[]
  reviews         Review[]
  savedBy         SavedCollege[]
  cutoffs         Cutoff[]
  questions       Question[]
  createdAt       DateTime       @default(now())

  @@index([city])
  @@index([fees])
  @@index([rating])
}

model Course {
  id        String  @id @default(cuid())
  name      String
  duration  String
  fees      Int
  collegeId String
  college   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model Placement {
  id              String   @id @default(cuid())
  year            Int
  avgPackage      Int
  highestPackage  Int
  topRecruiters   String[]
  collegeId       String
  college         College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  comment    String
  authorName String   @default("Anonymous")
  collegeId  String
  college    College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model SavedCollege {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, collegeId])
}

model Cutoff {
  id          String  @id @default(cuid())
  examName    String
  courseName  String
  openingRank Int
  closingRank Int
  year        Int
  collegeId   String
  college     College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([examName])
  @@index([closingRank])
}

model Question {
  id        String   @id @default(cuid())
  title     String
  body      String
  collegeId String?
  college   College? @relation(fields: [collegeId], references: [id], onDelete: SetNull)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  answers   Answer[]
  createdAt DateTime @default(now())
}

model Answer {
  id         String   @id @default(cuid())
  body       String
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}